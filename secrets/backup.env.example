# Backup config for scripts/pg_dump_to_r2.sh and scripts/restore_from_r2.sh.
# Copy to secrets/backup.env (gitignored) and fill in. Kept SEPARATE from .env.prod so the scoped
# R2 backup token is never injected into the API container (least privilege).
#
#   cp secrets/backup.env.example secrets/backup.env && $EDITOR secrets/backup.env

# R2 S3 endpoint — https://<accountid>.r2.cloudflarestorage.com
R2_BACKUP_ENDPOINT=https://CHANGE-ME.r2.cloudflarestorage.com
# Dedicated backups bucket (NOT the attachments bucket).
R2_BACKUP_BUCKET=vet-backups
# Key prefix within the bucket (trailing slash optional).
R2_BACKUP_PREFIX=pg/
# A *scoped* R2 API token — Object Read & Write on the backups bucket only.
R2_BACKUP_ACCESS_KEY=change-me
R2_BACKUP_SECRET_KEY=change-me
# Informational only: 30-day retention is enforced by an R2 lifecycle rule (see RUNBOOK), not the script.
RETENTION_DAYS=30
