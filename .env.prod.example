# Production environment file — COPY to .env.prod (gitignored) and fill in real values.
#
#   cp .env.prod.example .env.prod && $EDITOR .env.prod
#
# Used two ways by docker-compose.prod.yaml, both requiring `--env-file .env.prod` on the CLI:
#   1. ${...} interpolation in the compose file (PG_PASSWORD, DOMAIN, image tags).
#   2. env_file: on the `api` service — every Section__Key below is injected as a .NET env var
#      (the `__` becomes the `:` config separator).
#
# The PowerSync RSA signing keypair is the ONE secret that is NOT here — env files can't portably
# carry multi-line PEMs. It lives in secrets/appsettings.Production.json (see secrets/README.md).

# ── Compose interpolation ────────────────────────────────────────────────────
# Postgres superuser password. Reused by the API connection string and the PowerSync URI (compose
# derives both from it — do not also set ConnectionStrings__Postgres here).
PG_PASSWORD=change-me-strong-postgres-password
# Base domain. nginx serves api.${DOMAIN} and sync.${DOMAIN}.
DOMAIN=example.com
# Pin the PowerSync service image (keep aligned with the mobile SDK).
POWERSYNC_IMAGE_TAG=1.10.2
# .NET base-image tag used by the Dockerfile build.
DOTNET_VERSION=10.0

# ── API secrets & tunables (Section__Key → injected into the api container) ───
# User-token JWT signing key. MUST be ≥ 32 chars (HS256). Generate: openssl rand -base64 48
Jwt__SecretKey=change-me-min-32-char-random-hs256-secret-xxxxxxxxxxxx

# Cloudflare R2 (S3-compatible). Use an R2 *user* API token (Access Key ID + Secret), not an
# account-level token. ServiceUrl is https://<accountid>.r2.cloudflarestorage.com
R2__ServiceUrl=https://CHANGE-ME.r2.cloudflarestorage.com
R2__AccessKey=change-me
R2__SecretKey=change-me
R2__Bucket=vet-attachments

# Bootstrap admin password (seeded on the first `--seed` run; +970000000000 is the seeded phone).
# Change it via the app immediately after first login.
BootstrapAdmin__Password=change-me-min-8-chars

# Optional structured-log sink (Seq). Leave empty for rolling-file logging only.
Seq__ServerUrl=

# Optional crash/error reporting (Sentry). Leave Dsn empty to disable (default). The DSN is in your
# Sentry project under Settings → Client Keys (DSN). Environment defaults to the ASP.NET environment
# ("Production"); Release defaults to the API assembly version — set it to your deploy's git SHA/tag
# for per-deploy issue grouping. TracesSampleRate 0.0 = errors only (no performance tracing); raise
# (e.g. 0.05) to sample transactions. See RUNBOOK "Observability" and vet-backend/CLAUDE.md "Operations".
Sentry__Dsn=
# Sentry__Environment=production
# Sentry__Release=
# Sentry__TracesSampleRate=0.0

# Optional: in-process Hangfire worker count (default 1). See RUNBOOK "Scale the Hangfire worker".
# Hangfire__WorkerCount=1
